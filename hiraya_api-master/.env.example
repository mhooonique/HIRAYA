# HIRAYA API — Environment Configuration Template
# Copy this file to .env and fill in your real values.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3307
DB_NAME=db_hiraya
DB_USER=root
DB_PASS=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=

# ── Mail (Gmail SMTP) ─────────────────────────────────────────────────────────
# Use a Gmail App Password (myaccount.google.com → Security → App Passwords)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=
MAIL_FROM=your@gmail.com
MAIL_NAME=HIRAYA Platform

# ── App URLs ──────────────────────────────────────────────────────────────────
APP_URL=https://your-frontend-domain.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:8080,https://your-frontend-domain.com
